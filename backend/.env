# ─────────────────────────────────────────────────
# Environment: development (local / SQLite)
# ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Database — choose one:
# SQLite (local/offline/Electron)
DB_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# PostgreSQL (cloud) — uncomment and fill when deploying
# DB_PROVIDER=postgresql
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/yarn_fabric_db?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_!!!
JWT_EXPIRES_IN=7d

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173
