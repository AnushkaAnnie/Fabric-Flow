# ─────────────────────────────────────────────────
# Environment Example — copy to .env and fill in values
# ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# SQLite (local / offline / Electron)
DB_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# PostgreSQL (cloud)
# DB_PROVIDER=postgresql
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/yarn_fabric_db?schema=public"

JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173
