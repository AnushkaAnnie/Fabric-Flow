generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
}

model MillName {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  address_line1 String?
  address_line2 String?
  address_line3 String?
  state         String?
  pin_code      String?
  gstn          String?
  email         String?
  createdAt     DateTime @default(now())
  yarns         Yarn[]
}

model KnitterName {
  id                    Int              @id @default(autoincrement())
  name                  String           @unique
  address_line1         String?
  address_line2         String?
  address_line3         String?
  state                 String?
  pin_code              String?
  gstn                  String?
  email                 String?
  yarn_balance          Float            @default(0)
  createdAt             DateTime         @default(now())
  knittings             Knitting[]
  knitterStocks         KnitterStock[]
  deliveryNotesSent     DeliveryNote[]   @relation("SourceKnitterTransfers")
  deliveryNotesReceived DeliveryNote[]   @relation("DestKnitterTransfers")
  knitterPrograms       KnitterProgram[]
}

model DyerName {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  address_line1 String?
  address_line2 String?
  address_line3 String?
  state         String?
  pin_code      String?
  gstn          String?
  email         String?
  createdAt     DateTime      @default(now())
  dyeings       Dyeing[]
  knittingLots  KnittingLot[]
}

model CompacterName {
  id            Int          @id @default(autoincrement())
  name          String       @unique
  address_line1 String?
  address_line2 String?
  address_line3 String?
  state         String?
  pin_code      String?
  gstn          String?
  email         String?
  createdAt     DateTime     @default(now())
  compactings   Compacting[]
  dyeings       Dyeing[]
}

model Colour {
  id                 Int                @id @default(autoincrement())
  name               String             @unique
  createdAt          DateTime           @default(now())
  dyeings            Dyeing[]
  compactings        Compacting[]
  knittingLotEntries KnittingLotEntry[]
}

model WashType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  dyeings   Dyeing[]
}

model FabricDescription {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  knittings Knitting[]
}

model Yarn {
  id                Int                 @id @default(autoincrement())
  hf_code           String
  purchase_order_no String              @default("")
  invoice_no        String              @default("")
  delivery_to       String              @default("")
  status            String              @default("Pending")
  millName          MillName            @relation(fields: [mill_name_id], references: [id])
  mill_name_id      Int
  description       String
  count             String
  quality           String
  no_of_bags        Float
  bag_weight        Float
  total_weight      Float
  available_weight  Float               @default(0)
  rate_per_kg       Float
  total_cost        Float
  issued_date       DateTime            @default(now())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  yarnUsages        KnittingYarnUsage[]
  receipts          YarnReceipt[]
  knitterStocks     KnitterStock[]
  deliveryNotes     DeliveryNote[]
  knitterPrograms   KnitterProgram[]
}

model InhouseKnittedFabric {
  id                Int      @id @default(autoincrement())
  fabric_code       String   @unique
  purchase_order_no String
  invoice_no        String   @default("")
  supplier_name_id  Int?
  particulars       String
  total_weight      Float
  rate_per_unit     Float
  amount            Float
  date              DateTime
  created_at        DateTime @default(now())
}

model KnittingYarnUsage {
  id          Int      @id @default(autoincrement())
  knitting    Knitting @relation(fields: [knitting_id], references: [id], onDelete: Cascade)
  knitting_id Int
  yarn        Yarn     @relation(fields: [yarn_id], references: [id])
  yarn_id     Int
  hf_code     String
  quantity    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnittingLot {
  id           Int                @id @default(autoincrement())
  knitting     Knitting           @relation(fields: [knitting_id], references: [id], onDelete: Cascade)
  knitting_id  Int
  lot_no       String             @unique
  job_work_no  String             @default("")
  no_of_rolls  Int                @default(0)
  dyerName     DyerName           @relation(fields: [dyer_name_id], references: [id])
  dyer_name_id Int
  entries      KnittingLotEntry[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model KnittingLotEntry {
  id              Int         @id @default(autoincrement())
  knittingLot     KnittingLot @relation(fields: [knitting_lot_id], references: [id], onDelete: Cascade)
  knitting_lot_id Int
  colour          Colour      @relation(fields: [colour_id], references: [id])
  colour_id       Int
  weight          Float
  dyeing_id       Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Knitting {
  id                    Int                 @id @default(autoincrement())
  hf_code               String
  dc_no                 String              @unique
  knitterName           KnitterName         @relation(fields: [knitter_name_id], references: [id])
  knitter_name_id       Int
  total_yarn_qty        Float               @default(0)
  loop_length           Float
  dia                   Float
  count                 String
  gauge                 String
  date_given            DateTime
  fabricDescription     FabricDescription   @relation(fields: [fabric_description_id], references: [id])
  fabric_description_id Int
  grey_fabric_weight    Float
  received_weight       Float?
  other_yarn_type       String?
  other_yarn_percentage Float?
  no_of_rolls           Int
  date                  DateTime
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  yarnUsages            KnittingYarnUsage[]
  lots                  KnittingLot[]
  greyFabric            GreyFabric?
  dyeingLotIssues       DyeingLot[]
}

model KnitterStock {
  id               Int         @id @default(autoincrement())
  knitterName      KnitterName @relation(fields: [knitterId], references: [id])
  knitterId        Int
  yarn             Yarn        @relation(fields: [yarnId], references: [id])
  yarnId           Int
  received_weight  Float
  remaining_weight Float
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model DeliveryNote {
  id              Int         @id @default(autoincrement())
  sourceKnitter   KnitterName @relation("SourceKnitterTransfers", fields: [sourceKnitterId], references: [id])
  sourceKnitterId Int
  destKnitter     KnitterName @relation("DestKnitterTransfers", fields: [destKnitterId], references: [id])
  destKnitterId   Int
  yarn            Yarn        @relation(fields: [yarnId], references: [id])
  yarnId          Int
  quantity        Float
  transferDate    DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model KnitterProgram {
  id              Int            @id @default(autoincrement())
  knitterName     KnitterName    @relation(fields: [knitterId], references: [id])
  knitterId       Int
  yarn            Yarn           @relation(fields: [yarnId], references: [id])
  yarnId          Int
  quantity_used   Float
  grey_weight     Float
  number_of_rolls Int            @default(0)
  gauge           String?
  loop_length     Float?
  productionDate  DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  greyFabricLot   GreyFabricLot?
}

model GreyFabricLot {
  id               Int            @id @default(autoincrement())
  knitterProgram   KnitterProgram @relation(fields: [knitterProgramId], references: [id], onDelete: Cascade)
  knitterProgramId Int            @unique
  grey_weight      Float
  status           String         @default("AVAILABLE")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  dyeings          Dyeing[]
}

model Dyeing {
  id                Int              @id @default(autoincrement())
  lot_no            String
  hf_code           String?
  source_type       String?
  fabric_code       String?
  count             String?
  initial_weight    Float?
  gg                Float?
  initial_dia       Float?
  final_dia         Float?
  no_of_rolls       Int?
  final_weight      Float?
  process_loss      Float?
  date              DateTime         @default(now())
  dateGiven         DateTime?
  knitterDcNo       String?
  companyDcNo       String?
  compacterId       Int?
  greyFabricLotId   Int?             @unique
  colour_id         Int
  dyer_name_id      Int
  wash_type_id      Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  dyerName          DyerName         @relation(fields: [dyer_name_id], references: [id])
  washType          WashType?        @relation(fields: [wash_type_id], references: [id])
  colour            Colour           @relation(fields: [colour_id], references: [id])
  greyFabricLot     GreyFabricLot?   @relation(fields: [greyFabricLotId], references: [id])
  compacter         CompacterName?   @relation(fields: [compacterId], references: [id])

  @@map("dyeings")
}

model Compacting {
  id                Int           @id @default(autoincrement())
  hf_code           String
  count             String        @default("")
  lot_no            String        @unique
  initial_weight    Float
  compacterName     CompacterName @relation(fields: [compacter_name_id], references: [id])
  compacter_name_id Int
  final_dia         Float
  colour            Colour        @relation(fields: [colour_id], references: [id])
  colour_id         Int
  final_weight      Float
  process_loss      Float
  date              DateTime
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model YarnReceipt {
  id          Int      @id @default(autoincrement())
  yarn        Yarn     @relation(fields: [yarnId], references: [id])
  yarnId      Int
  quantity    Float
  receiptDate DateTime @default(now())
  dcNo        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GreyFabric {
  id          Int      @id @default(autoincrement())
  knitting    Knitting @relation(fields: [knittingId], references: [id])
  knittingId  Int      @unique
  description String
  gauge       String?
  loopLength  Float?
  diameter    Float?
  gsm         Float?
  quantity    Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DyeingOrder {
  id        Int         @id @default(autoincrement())
  dcNo      String      @unique
  dyerName  String
  issueDate DateTime    @default(now())
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  lots      DyeingLot[]
}

model DyeingLot {
  id            Int         @id @default(autoincrement())
  dyeingOrder   DyeingOrder @relation(fields: [dyeingOrderId], references: [id])
  dyeingOrderId Int
  knitting      Knitting    @relation(fields: [knittingId], references: [id])
  knittingId    Int
  colour        String
  weight        Float
  createdAt     DateTime    @default(now())
}
