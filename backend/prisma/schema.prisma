generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Change to "postgresql" manually for cloud
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         String   @default("user") // "admin" | "user"
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────────────
// MASTER DATA TABLES
// ─────────────────────────────────────────────────────

model MillName {
  id        Int      @id @default(autoincrement())
  name          String   @unique
  address_line1 String?
  address_line2 String?
  address_line3 String?
  state         String?
  pin_code      String?
  gstn          String?
  createdAt DateTime @default(now())
  yarns     Yarn[]
}

model KnitterName {
  id        Int        @id @default(autoincrement())
  name          String     @unique
  address_line1 String?
  address_line2 String?
  address_line3 String?
  state         String?
  pin_code      String?
  gstn          String?
  createdAt DateTime   @default(now())
  knittings Knitting[]
}

model DyerName {
  id        Int      @id @default(autoincrement())
  name          String   @unique
  address_line1 String?
  address_line2 String?
  address_line3 String?
  state         String?
  pin_code      String?
  gstn          String?
  createdAt DateTime @default(now())
  dyeings   Dyeing[]
}

model CompacterName {
  id          Int          @id @default(autoincrement())
  name          String       @unique
  address_line1 String?
  address_line2 String?
  address_line3 String?
  state         String?
  pin_code      String?
  gstn          String?
  createdAt   DateTime     @default(now())
  compactings Compacting[]
}

model Colour {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  createdAt   DateTime     @default(now())
  dyeings     Dyeing[]
  compactings Compacting[]
}

model WashType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  dyeings   Dyeing[]
}

model FabricDescription {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now())
  knittings Knitting[]
}

// ─────────────────────────────────────────────────────
// CORE PRODUCTION TABLES
// ─────────────────────────────────────────────────────

model Yarn {
  id                Int        @id @default(autoincrement())
  hf_code           String
  purchase_order_no String     @default("")
  invoice_no        String     @default("")
  delivery_to       String     @default("")
  status            String     @default("Pending")
  millName          MillName   @relation(fields: [mill_name_id], references: [id])
  mill_name_id Int
  description  String
  count        String
  quality      String     // "rl" or "vl"
  no_of_bags   Float
  bag_weight   Float
  total_weight Float      
  rate_per_kg  Float
  total_cost   Float      
  issued_date  DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Knitting {
  id                    Int               @id @default(autoincrement())
  hf_code               String
  knitterName           KnitterName       @relation(fields: [knitter_name_id], references: [id])
  knitter_name_id       Int
  yarn_quantity         Float
  loop_length           Float
  dia                   Float
  count                 String
  gauge                 String
  date_given            DateTime
  fabricDescription     FabricDescription @relation(fields: [fabric_description_id], references: [id])
  fabric_description_id Int
  grey_fabric_weight    Float
  other_yarn_type       String?
  other_yarn_percentage Float?
  no_of_rolls           Int
  date                  DateTime
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model Dyeing {
  id             Int      @id @default(autoincrement())
  hf_code        String
  count          String   @default("")
  lot_no         String   @unique
  initial_weight Float
  dyerName       DyerName @relation(fields: [dyer_name_id], references: [id])
  dyer_name_id   Int
  washType       WashType @relation(fields: [wash_type_id], references: [id])
  wash_type_id   Int
  colour         Colour   @relation(fields: [colour_id], references: [id])
  colour_id      Int
  gg             Float
  initial_dia    Float
  final_dia      Float
  no_of_rolls    Int
  final_weight   Float
  process_loss   Float    // added
  date           DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Compacting {
  id                Int      @id @default(autoincrement())
  hf_code           String
  count             String   @default("")
  lot_no            String   @unique
  initial_weight    Float
  compacterName     CompacterName @relation(fields: [compacter_name_id], references: [id])
  compacter_name_id Int
  final_dia         Float
  colour            Colour   @relation(fields: [colour_id], references: [id])
  colour_id         Int
  final_weight      Float
  process_loss      Float    // auto
  date              DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
